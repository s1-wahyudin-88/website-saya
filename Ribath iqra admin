  <script>
    /**
     * KONFIGURASI UTAMA
     * Ganti dengan URL Web App dari Google Apps Script Anda
     */
    const API_URL = "https://script.google.com/macros/s/AKfycbzkuT9IDZ2THmNK0Eeo8453ZREM9NqI970SYx1KeAYM-jocPL8nof4U7tBlCPmBEpku/exec";
    let adminToken = sessionStorage.getItem("admin_token");
    let currentPinInput = "";

    // ── Helper API ──────────────────────────────────────────────
    async function api(action, method = "GET", payload = {}) {
      if (!adminToken && action !== "validateAdminPin") {
        alert("Sesi habis. Silakan login ulang.");
        logout();
        return null;
      }

      let url = `${API_URL}?action=${action}`;
      const options = { method };

      if (method === "GET") {
        if (adminToken) url += `&token=${encodeURIComponent(adminToken)}`;
        Object.entries(payload).forEach(([k, v]) => url += `&${k}=${encodeURIComponent(v)}`);
        const res = await fetch(url);
        return res.json();
      } else {
        // doPost GAS butuh text/plain untuk hindari CORS preflight
        options.headers = { "Content-Type": "text/plain;charset=utf-8" };
        options.body = JSON.stringify({ action, token: adminToken, ...payload });
        const res = await fetch(API_URL, options);
        return res.json();
      }
    }

    // ── Auth & Session ──────────────────────────────────────────
    function handleKey(val) {
      if (currentPinInput.length < 6) {
        currentPinInput += val;
        document.getElementById("pin-display").value = "•".repeat(currentPinInput.length);
      }
    }
    function handleBackspace() {
      currentPinInput = currentPinInput.slice(0, -1);
      document.getElementById("pin-display").value = "•".repeat(currentPinInput.length);
    }

    document.querySelectorAll(".key").forEach(btn => {
      btn.addEventListener("click", () => handleKey(btn.dataset.val));
    });
    document.getElementById("btn-backspace").addEventListener("click", handleBackspace);

    document.getElementById("btn-login-submit").addEventListener("click", async () => {
      const res = await api("validateAdminPin", "POST", { pin: currentPinInput });
      if (res && res.success && res.data.valid) {
        adminToken = res.data.token;
        sessionStorage.setItem("admin_token", adminToken);
        document.getElementById("login-screen").style.display = "none";
        document.getElementById("admin-panel").style.display = "block";
        currentPinInput = "";
        loadAllData();
      } else {
        alert("PIN Admin salah!");
        currentPinInput = "";
        document.getElementById("pin-display").value = "";
      }
    });

    document.getElementById("btn-logout").addEventListener("click", logout);
    function logout() {
      sessionStorage.removeItem("admin_token");
      adminToken = null;
      location.reload();
    }

    // ── Navigasi ────────────────────────────────────────────────
    function switchSection(secId) {
      document.querySelectorAll("main section").forEach(s => s.style.display = "none");
      const target = document.getElementById(`sec-${secId}`);
      if (target) target.style.display = "block";
    }

    document.querySelectorAll("#main-nav button[data-section]").forEach(btn => {
      btn.addEventListener("click", () => switchSection(btn.dataset.section));
    });

    // ── Load Data ───────────────────────────────────────────────
    async function loadAllData() {
      loadSantri();
      loadKalender();
      loadPengumuman();
      loadLembaga();
    }

    async function loadSantri() {
      const res = await api("getAllSantri");
      if (!res?.success) return;
      const tbody = document.getElementById("santri-body");
      tbody.innerHTML = "";
      res.data.forEach(s => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td>${s.nama}</td><td>${s.level}</td><td>${s.pin}</td>
          <td>${s.aktif ? "Aktif" : "Nonaktif"}</td>
          <td><button class="btn-del-santri" data-id="${s.id}">Hapus</button></td>
        `;
        tbody.appendChild(tr);
      });
      document.querySelectorAll(".btn-del-santri").forEach(btn => {
        btn.addEventListener("click", async () => {
          if (confirm("Hapus santri ini?")) {
            await api("deleteSantri", "POST", { id: parseInt(btn.dataset.id) });
            loadSantri();
          }
        });
      });
    }

    async function loadKalender() {
      const res = await api("getKalender");
      if (!res?.success) return;
      const tbody = document.getElementById("kalender-body");
      tbody.innerHTML = "";
      res.data.forEach(k => {
        const tr = document.createElement("tr");
        tr.innerHTML = `<td>${k.hari}</td><td>${k.bulan}</td><td>${k.judul}</td><td>${k.type}</td>
                        <td><button class="btn-del-event" data-id="${k.id}">🗑️</button></td>`;
        tbody.appendChild(tr);
      });
      document.querySelectorAll(".btn-del-event").forEach(btn => {
        btn.addEventListener("click", async () => {
          await api("deleteKalender", "POST", { id: parseInt(btn.dataset.id) });
          loadKalender();
        });
      });
    }

    async function loadPengumuman() {
      const res = await api("getPengumuman");
      if (res?.success) {
        document.getElementById("pengumuman-text").value = res.data.teks || "";
        document.getElementById("pengumuman-preview").textContent = res.data.teks || "";
      }
    }

    async function loadLembaga() {
      const res = await api("getLembaga");
      if (res?.success) {
        document.getElementById("lembaga-nama").value = res.data.nama || "";
        document.getElementById("lembaga-alamat").value = res.data.alamat || "";
        document.getElementById("lembaga-wa").value = res.data.wa || "";
        document.getElementById("lembaga-ig").value = res.data.instagram || "";
      }
    }

    // ── Form Handlers ───────────────────────────────────────────
    // Santri
    document.getElementById("btn-open-add-santri").addEventListener("click", () => document.getElementById("modal-santri").style.display = "block");
    document.getElementById("modal-santri-cancel").addEventListener("click", () => document.getElementById("modal-santri").style.display = "none");
    document.getElementById("modal-santri-save").addEventListener("click", async () => {
      const data = {
        nama: document.getElementById("modal-santri-nama").value,
        level: document.getElementById("modal-santri-level").value,
        pin: document.getElementById("modal-santri-pin").value
      };
      if (!data.nama || data.pin.length !== 4) return alert("Lengkapi data & PIN 4 digit");
      const res = await api("saveSantri", "POST", { data });
      if (res?.success) {
        document.getElementById("modal-santri").style.display = "none";
        loadSantri();
      }
    });

    // Event
    document.getElementById("btn-add-event").addEventListener("click", () => document.getElementById("modal-event").style.display = "block");
    document.getElementById("modal-event-cancel").addEventListener("click", () => document.getElementById("modal-event").style.display = "none");
    document.getElementById("modal-event-save").addEventListener("click", async () => {
      const data = {
        hari: document.getElementById("modal-event-tgl").value,
        bulan: document.getElementById("modal-event-bulan").value,
        judul: document.getElementById("modal-event-judul").value,
        type: document.getElementById("modal-event-tipe").value,
        icon: document.getElementById("modal-event-icon").value,
        catatan: document.getElementById("modal-event-catatan").value
      };
      const res = await api("saveKalender", "POST", { data });
      if (res?.success) {
        document.getElementById("modal-event").style.display = "none";
        loadKalender();
      }
    });

    // Pengumuman
    document.getElementById("pengumuman-text").addEventListener("input", (e) => {
      document.getElementById("pengumuman-preview").textContent = e.target.value;
    });
    document.getElementById("btn-save-pengumuman").addEventListener("click", async () => {
      const res = await api("savePengumuman", "POST", { teks: document.getElementById("pengumuman-text").value });
      if (res?.success) alert("Pengumuman berhasil disimpan!");
    });

    // Statistik
    document.getElementById("btn-publish-stat").addEventListener("click", async () => {
      const start = document.getElementById("stat-start").value;
      const end = document.getElementById("stat-end").value;
      const label = document.getElementById("stat-label").value;
      if (!start || !end || !label) return alert("Isi periode & label");
      const res = await api("publishStatistik", "POST", { start, end, label });
      if (res?.success) {
        alert("Statistik berhasil dipublish!");
        document.getElementById("stat-preview").innerHTML = JSON.stringify(res.data, null, 2);
      }
    });

    // Lembaga
    document.getElementById("btn-save-lembaga").addEventListener("click", async () => {
      const data = {
        nama: document.getElementById("lembaga-nama").value,
        alamat: document.getElementById("lembaga-alamat").value,
        wa: document.getElementById("lembaga-wa").value,
        instagram: document.getElementById("lembaga-ig").value
      };
      await api("saveLembaga", "POST", { data });
      alert("Info lembaga disimpan");
    });

    // Ganti PIN (Catatan: PIN Admin hanya bisa diganti di backend konstanta. 
    // Jika ingin ganti via UI, perlu modifikasi backend. Ini hanya placeholder UI)
    document.getElementById("btn-open-change-pin").addEventListener("click", () => document.getElementById("modal-pin").style.display = "block");
    document.getElementById("modal-pin-cancel").addEventListener("click", () => document.getElementById("modal-pin").style.display = "none");
    document.getElementById("modal-pin-save").addEventListener("click", () => {
      alert("Untuk keamanan, ganti PIN_ADMIN langsung di file ribath-apps-script.js baris paling atas, lalu deploy ulang.");
      document.getElementById("modal-pin").style.display = "none";
    });

    // Export & Reset UI
    document.getElementById("btn-export").addEventListener("click", async () => {
      const santri = await api("getAllSantri");
      const daily = await api("getHarianRange", "GET", { id: 1, start: "2020-01-01", end: "2099-12-31" }); // Contoh fetch
      const blob = new Blob([JSON.stringify({ santri: santri?.data, harian: daily?.data }, null, 2)], { type: "application/json" });
      const a = document.createElement("a");
      a.href = URL.createObjectURL(blob);
      a.download = `backup_ribath_${new Date().toISOString().slice(0,10)}.json`;
      a.click();
    });

    // Inisialisasi
    if (adminToken) {
      document.getElementById("login-screen").style.display = "none";
      document.getElementById("admin-panel").style.display = "block";
      loadAllData();
    }
  </script>
</body>
</html>
